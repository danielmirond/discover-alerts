{
  "//": "Fórmulas declarativas sugeridas para cada alerta. Se muestran como bloque 'context' al final del mensaje Slack. Matching jerárquico: la regla más específica gana. Placeholders soportados: {entity}, {category}, {topic}, {ngram}, {trend}, {count}, {outlets}, {traffic}. Editables sin redeploy.",
  "rules": [
    {
      "match": { "type": "trends_without_discover", "topic": "legal" },
      "lines": [
        "{entity}: la clave juridica que nadie te esta explicando",
        "Sentencia / auto / fallo sobre {entity}: lo que significa",
        "Asi queda {entity} tras la decision judicial"
      ]
    },
    {
      "match": { "type": "trends_without_discover", "topic": "sucesos" },
      "lines": [
        "Ultima hora: {entity} - todo lo que sabemos",
        "{entity}: como ha ocurrido minuto a minuto",
        "Claves del suceso: {entity}"
      ]
    },
    {
      "match": { "type": "trends_without_discover" },
      "lines": [
        "{entity}: la respuesta a lo que todos buscan",
        "Por que {entity} es tendencia hoy",
        "Todo sobre {entity}: claves y ultima hora"
