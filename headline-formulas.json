        "{entity}: el dato que todos repiten"
      ]
    },
    {
      "match": { "type": "entity_coverage" },
      "lines": [
        "{entity}: diferenciate del resto de medios",
        "{entity}: el matiz que nadie cuenta",
        "Por que {entity} es tendencia en {outlets}+ medios"
      ]
    },

    {
      "match": { "type": "entity_concordance", "subtype": "discover_trends_x" },
      "lines": [
        "{entity}: triple match Discover + Trends + X",
        "{entity} domina Google y redes: aprovecha el pico",
        "Por que {entity} es el tema del momento"
      ]
    },
    {
      "match": { "type": "entity_concordance" },
      "lines": [
        "{entity}: tendencia multicanal",
        "Google + Medios + X: {entity} esta en todas",
        "Claves de por que {entity} es tendencia"
      ]
    },

    {
      "match": { "type": "multi_entity_article", "topic": "legal" },
      "lines": [
        "{entity}: el cruce juridico que explica el caso",
        "Asi conectan {entity} en una misma noticia",
        "Claves de la conexion entre {entity}"
      ]
    },
    {
      "match": { "type": "multi_entity_article" },
      "lines": [
        "{entity}: el cruce que explica la noticia",
        "Asi conectan {entity}: claves del articulo",
        "Por que {entity} aparecen juntos hoy"
      ]
    },

    {
      "match": { "type": "headline_pattern" },
      "lines": [
        "Ni {ngram}: la realidad sobre el tema",
        "Mas alla de \"{ngram}\": el angulo diferente",
        "Todos hablan de \"{ngram}\": nosotros te lo explicamos"
      ]
    },

    {
      "match": { "type": "headline_cluster" },
      "lines": [
        "Evento en curso: {count} frentes abiertos",
        "Cobertura en directo del evento",
        "Minuto a minuto de un evento grande"
      ]
    }
