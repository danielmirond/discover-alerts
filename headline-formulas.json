        "{entity}: las claves que mantienen viva la noticia",
        "Por que {entity} sigue siendo tendencia"
      ]
    },
    {
      "match": { "type": "entity", "subtype": "rising" },
      "lines": [
        "{entity} se dispara: +{count} puntos en minutos",
