    },
    {
      "match": { "type": "entity", "subtype": "ascending", "topic": "sucesos" },
      "lines": [
        "{entity}: ultimas novedades de la investigacion",
        "Sigue la busqueda / investigacion de {entity}",
        "{entity}: el caso que no para"
      ]
