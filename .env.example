# Required
DISCOVERSNOOP_TOKEN=your_bearer_token_here
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Optional - Slack webhooks por categoria/topic (definidos en routing.json)
# Si no se definen, esos alerts caen al SLACK_WEBHOOK_URL por defecto.
# SLACK_WEBHOOK_DEPORTES=https://hooks.slack.com/services/xxx
# SLACK_WEBHOOK_POLITICA=https://hooks.slack.com/services/xxx
# SLACK_WEBHOOK_TECH=https://hooks.slack.com/services/xxx
# SLACK_WEBHOOK_ENTRETENIMIENTO=https://hooks.slack.com/services/xxx
# SLACK_WEBHOOK_ECONOMIA=https://hooks.slack.com/services/xxx
# SLACK_WEBHOOK_SUCESOS=https://hooks.slack.com/services/xxx    # topic: sucesos (crimenes, desapariciones)
# SLACK_WEBHOOK_LEGAL=https://hooks.slack.com/services/xxx      # topic: legal (sentencias, tribunales)

# Optional - Override del fichero de topics (default: topics.json)
# TOPICS_PATH=topics.json

# Upstash Redis (required for Vercel deploy)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# Vercel Cron secret (auto-generated by Vercel, or set your own)
CRON_SECRET=your_cron_secret_here

# Optional - DiscoverSnoop params
# DISCOVER_COUNTRY=ES
# DISCOVER_HOURS=6
# DISCOVER_LINES=100

# Optional - Alert thresholds
# THRESHOLD_ENTITY_SCORE_JUMP=20
# THRESHOLD_ENTITY_NEW_MIN_SCORE=10
# THRESHOLD_CATEGORY_SCORE_JUMP=15
# THRESHOLD_CATEGORY_PUB_JUMP_PCT=0.5
# THRESHOLD_HEADLINE_MIN_FREQUENCY=3
# THRESHOLD_TREND_CORRELATION_MIN=0.6

# Optional - Dedup
# DEDUP_WINDOW_HOURS=6
